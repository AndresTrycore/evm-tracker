APP_ENV=development

# PostgreSQL (usado por docker compose y por el backend para construir DATABASE_URL)
POSTGRES_USER=evm_user
POSTGRES_PASSWORD=evm_password
POSTGRES_DB=evm_db

# Backend DB settings
DB_HOST=db
DB_PORT=5432
DB_NAME=evm_db
DB_USER=evm_user
DB_PASSWORD=evm_password

# Opcional: si se define, tiene prioridad sobre DB_*
# DATABASE_URL=postgresql://evm_user:evm_password@db:5432/evm_db
